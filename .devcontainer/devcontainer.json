{
  "name": "Flutter Team Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "postStartCommand": "adb connect host.docker.internal:5555",
  "customizations": {
    "vscode": {
      "extensions": [
        "dart-code.dart-code",
        "dart-code.flutter"
      ]
    }
  },
  "remoteUser": "root"
}